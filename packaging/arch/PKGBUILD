pkgname=helm
pkgver=0.1.0
pkgrel=1
pkgdesc='Local password vault whose master password is never stored'
arch=('x86_64')
license=('MIT')
depends=('gcc-libs' 'glibc' 'libx11' 'libxcb' 'libxkbcommon' 'wayland')
makedepends=('cargo')
options=('!lto')

package() {
  install -Dm755 "$startdir/../../target/release/helm" "$pkgdir/usr/bin/helm"
  install -Dm644 "$startdir/../linux/helm.desktop" "$pkgdir/usr/share/applications/helm.desktop"
  install -Dm644 "$startdir/../../assets/icons/helm-512.png" "$pkgdir/usr/share/icons/hicolor/512x512/apps/helm.png"
}
